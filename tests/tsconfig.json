{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "noEmit": true,
    "paths": {
      "@app-base": ["tests/abstractClass.ts"],
      "@app-fixtures": ["tests/fixtures.ts"],
      "@app-pages/*": ["tests/pages/*"],
      "@app-components/*": ["tests/components/*"],
      "@app-helpers/*": ["helpers/*"],
      "@app-types/*": ["types/*"],
      "@app-utils/*": ["utils/*"],
      "@app-constants/*": ["constants/*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
